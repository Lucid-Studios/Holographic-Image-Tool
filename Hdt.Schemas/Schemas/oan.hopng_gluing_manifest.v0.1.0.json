{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oan.hopng_gluing_manifest.v0.1.0.json",
  "title": "HOPNG Gluing Manifest",
  "type": "object",
  "required": ["schema", "schemaVersion", "artifactId", "relations"],
  "properties": {
    "schema": { "const": "oan.hopng_gluing_manifest" },
    "schemaVersion": { "const": "0.1.0" },
    "artifactId": { "type": "string" },
    "relations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/relation" }
    }
  },
  "$defs": {
    "relation": {
      "type": "object",
      "required": [
        "relationId",
        "sourceUniverseId",
        "targetUniverseId",
        "relationType",
        "requiredForFormation"
      ],
      "properties": {
        "relationId": { "type": "string" },
        "sourceUniverseId": { "type": "string" },
        "targetUniverseId": { "type": "string" },
        "relationType": { "type": "string" },
        "requiredForFormation": { "type": "boolean" }
      }
    }
  }
}
