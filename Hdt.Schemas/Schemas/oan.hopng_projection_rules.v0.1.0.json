{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oan.hopng_projection_rules.v0.1.0.json",
  "title": "HOPNG Projection Rules",
  "type": "object",
  "required": ["schema", "schemaVersion", "artifactId", "rules"],
  "properties": {
    "schema": { "const": "oan.hopng_projection_rules" },
    "schemaVersion": { "const": "0.1.0" },
    "artifactId": { "type": "string" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": [
        "ruleId",
        "sourceUniverseId",
        "targetProjectionRole",
        "mappingType",
        "precedence"
      ],
      "properties": {
        "ruleId": { "type": "string" },
        "sourceUniverseId": { "type": "string" },
        "targetProjectionRole": { "type": "string" },
        "mappingType": { "type": "string" },
        "precedence": { "type": "integer" }
      }
    }
  }
}
